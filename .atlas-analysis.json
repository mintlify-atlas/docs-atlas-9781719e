  "keyFeatures": [
    "Multiple backend support (PyTorch, TensorRT, AutoDeploy)",
    "Advanced quantization (FP8, FP4, INT8, INT4 with AWQ/GPTQ)",
    "Speculative decoding with 6+ algorithms (EAGLE-3, NGram, MTP)",
    "Disaggregated serving for optimized prefill and decode",
    "Distributed inference with tensor/pipeline/expert parallelism",
    "Production-ready serving with OpenAI-compatible API",
    "Comprehensive model support (50+ architectures including multimodal)"
  ],
  "publicApiSurface": [
    "LLM - Main inference class",
    "AsyncLLM - Asynchronous inference wrapper",
    "SamplingParams - Generation parameter configuration",
    "LlmArgs/TorchLlmArgs/TrtLlmArgs - Backend configuration classes",
    "GenerationExecutor - Low-level execution interface",
    "AutoModelForCausalLM - Auto model loading",
    "trtllm-serve - Production serving CLI",
    "trtllm-bench - Benchmarking CLI",
    "Eagle3DecodingConfig - Speculative decoding configuration",
    "KvCacheConfig - KV cache management configuration",
    "GuidedDecodingParams - Structured output configuration",
    "QuantAlgo/QuantMode - Quantization enums and utilities"
  ]
